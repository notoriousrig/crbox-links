# Copy to .env and fill in. .env is gitignored.

# --- Cloudflare Access ---
# Zero Trust team domain, e.g. "crbox.cloudflareaccess.com"
CF_ACCESS_TEAM_DOMAIN=crbox.cloudflareaccess.com
# Application AUD tag. Created when you add an Access app for links.crbox.ca.
# Find it under Access -> Applications -> your app -> Overview.
CF_ACCESS_AUD=

# --- App ---
LOG_LEVEL=INFO
# Hour (server local time, 0-23) to run nightly jobs
LINKCHECK_HOUR=3
BACKUP_HOUR=4
BACKUP_KEEP_DAYS=30
